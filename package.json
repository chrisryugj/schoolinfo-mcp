{
  "name": "schoolinfo-mcp",
  "version": "0.2.0",
  "description": "학교알리미(schoolinfo.go.kr) 공시정보 MCP 서버 + CLI — 학교 비교·수행평가·공시를 학부모가 쓸 수 있게. 흩어진 학교알리미를 한 표로",
  "type": "module",
  "bin": {
    "schoolinfo": "dist/cli.js",
    "schoolinfo-mcp": "dist/mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/regions.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/server.js",
    "mcp": "node dist/mcp.js",
    "cli": "tsx src/cli.ts",
    "serve": "tsx src/server.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "keywords": [
    "schoolinfo",
    "학교알리미",
    "education",
    "korea",
    "mcp",
    "model-context-protocol",
    "수행평가",
    "평가계획",
    "공시정보",
    "학교비교",
    "내신",
    "고교선택"
  ],
  "author": "chrisryugj",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "iconv-lite": "^0.6.3",
    "kordoc": "^3.1.1",
    "pdfjs-dist": "^4.10.38",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
